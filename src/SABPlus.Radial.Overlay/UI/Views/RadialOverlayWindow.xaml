<Window x:Class="SABPlus.Radial.Overlay.UI.Views.RadialOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SABPlus.Radial.Overlay.UI.Controls"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        Topmost="True"
        WindowStyle="None">
    <Grid Background="Transparent">
        <controls:RadialWheelControl x:Name="WheelControl" />
    </Grid>
</Window>
